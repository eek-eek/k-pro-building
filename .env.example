# ── AI Smeta KZ — backend configuration ────────────────────────────────────
# Скопируйте в .env и заполните. .env в git не коммитится.

# LLM-провайдер: gemini | anthropic | openai | demo
LLM_PROVIDER=gemini

# Ключи провайдеров (нужен только для выбранного выше)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Модели по провайдерам
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# Включать ли web-grounding (google_search) при извлечении норм
LLM_USE_SEARCH=true

# Строка подключения к БД (по умолчанию локальный SQLite)
DATABASE_URL=sqlite:///./data/ai_smeta.db

# Срок жизни кэша нормативного профиля, дней (0 = бессрочно)
KNOWLEDGE_CACHE_TTL_DAYS=180

# CORS: разрешённые origin фронтенда (через запятую, * для всех)
CORS_ORIGINS=*
