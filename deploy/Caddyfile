# Caddy v2 — обратный прокси для Yale Building Calculator.
#
# СЕЙЧАС (без домена): слушаем :80 на public IP инстанса.
#   ⚠ По HTTP пароль basic-auth идёт открыто. Это допустимо для короткого демо,
#     но как появится домен — переключитесь на него (ниже) и получите HTTPS.
#
# КОГДА БУДЕТ ДОМЕН: замените строку `:80 {` на `smeta.example.kz {`
#   (поставьте свой домен, A-запись → на public IP). Caddy сам выпустит
#   бесплатный сертификат Let's Encrypt — HTTPS заработает без других правок.
#
# (Опция — шифрование уже сейчас, до домена: замените `:80 {` на `:443 {`
#  и добавьте строкой ниже `tls internal`. Будет HTTPS с предупреждением
#  браузера (самоподписанный), но пароль уже не в открытом виде.)

:80 {
	encode zstd gzip

	# Логин/пароль на весь сайт, чтобы посторонние не жгли ключи ИИ.
	# Сгенерируйте хеш на сервере:  caddy hash-password --plaintext 'ВашПароль'
	# и вставьте его вместо REPLACE_WITH_BCRYPT_HASH (логин по умолчанию — admin).
	basic_auth {
		admin REPLACE_WITH_BCRYPT_HASH
	}

	reverse_proxy 127.0.0.1:8000
}
